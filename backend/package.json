{
  "name": "resilience-programme-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "build": "tsc -p tsconfig.json && node scripts/copy-prompt-assets.mjs",
    "smoke:health": "node scripts/smoke-health.mjs",
    "verify:prod": "npm run build && npm run smoke:health",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy"
  },
  "dependencies": {
    "@prisma/client": "^6.10.1",
    "dotenv": "^16.4.7",
    "fastify": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "prisma": "^6.10.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
