NODE_ENV=production
PORT=8787

AI_PROVIDER=deepseek
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=replace-me
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_TIMEOUT_MS=15000

# Use a real PostgreSQL URL before enabling persistent user/session data.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/resilience_programme
SESSION_SECRET=replace-with-a-long-random-string

# Comma-separated frontend origins allowed to call this backend.
CORS_ORIGIN=https://your-frontend.example.com,https://your-vercel-site.vercel.app
